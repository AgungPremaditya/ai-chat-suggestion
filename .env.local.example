# Project Settings > General > Reference ID → https://<ref-id>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=your-project-url

# API Keys > Publishable key (default)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-key

# API Keys > Secret key (server-side only, bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key
# Model to use for lead processing (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Internal secret for service-to-service calls — generate with: openssl rand -hex 32
PROCESS_INQUIRY_SECRET=your-random-secret

# Full URL of this app (used by submit-inquiry to call process-inquiry internally)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Mailtrap SMTP — https://mailtrap.io → Email Testing → SMTP Settings
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=587
MAILTRAP_USER=your-mailtrap-username
MAILTRAP_PASS=your-mailtrap-password
MAILTRAP_FROM="Dublin App" <noreply@dublin.app>
